# ============================================
# 仪器类产品研发管理系统 - 环境变量配置模板
# ============================================
# 复制此文件为 .env 并修改相应配置

# --------------------------------------------
# 服务器配置
# --------------------------------------------
SERVER_PORT=8080
BACKEND_PORT=8080
FRONTEND_PORT=5173
SPRING_PROFILE=dev

# --------------------------------------------
# 前端 - Token AES 加密密钥（必填，至少 32 字符）
# 生成方式：openssl rand -base64 32
# --------------------------------------------
VITE_TOKEN_SECRET=change-me-32-chars-minimum-secret-key-here

# --------------------------------------------
# 数据库配置
# --------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rd_system
DB_USERNAME=root
MYSQL_ROOT_PASSWORD=DevPass2026rd
DB_PASSWORD=DevPass2026rd

# --------------------------------------------
# Redis 配置
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# [必填] Redis密码,生产环境请使用强密码
REDIS_PASSWORD=changeme

# --------------------------------------------
# JWT 配置
# --------------------------------------------
# [必填] JWT密钥,至少32字符,建议使用 openssl rand -base64 32 生成
JWT_SECRET=

# --------------------------------------------
# 阿里云 OSS 配置（当 STORAGE_TYPE=aliyun-oss 时使用）
# --------------------------------------------
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=rd-files-prod

# --------------------------------------------
# 文件下载 HMAC 签名密钥（≥32 字符）
# --------------------------------------------
FILE_DOWNLOAD_SECRET=

# --------------------------------------------
# 跨域允许的 origin（逗号分隔多个）
# --------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --------------------------------------------
# 企业微信（Phase 1 留空也能跑，仅 OAuth 登录受影响）
# --------------------------------------------
WEWORK_CORP_ID=
WEWORK_AGENT_ID=
WEWORK_SECRET=
WEWORK_MESSAGE_ENABLED=false
