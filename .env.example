# ============================================
# 仪器类产品研发管理系统 - 环境变量配置模板
# ============================================
# 复制此文件为 .env 并修改相应配置

# --------------------------------------------
# 服务器配置
# --------------------------------------------
SERVER_PORT=8080
BACKEND_PORT=8080
FRONTEND_PORT=5173
SPRING_PROFILE=dev

# --------------------------------------------
# 前端 - Token AES 加密密钥（必填，至少 32 字符）
# 生成方式：openssl rand -base64 32
# --------------------------------------------
VITE_TOKEN_SECRET=change-me-32-chars-minimum-secret-key-here

# --------------------------------------------
# 数据库配置
# --------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=rd_system
DB_USERNAME=root
MYSQL_ROOT_PASSWORD=DevPass2026rd
DB_PASSWORD=DevPass2026rd

# --------------------------------------------
# Redis 配置
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
# [必填] Redis密码,生产环境请使用强密码
REDIS_PASSWORD=changeme

# --------------------------------------------
# JWT 配置
# --------------------------------------------
# [必填] JWT密钥,至少32字符,建议使用 openssl rand -base64 32 生成
JWT_SECRET=

# --------------------------------------------
# 阿里云 OSS 配置（当 STORAGE_TYPE=aliyun-oss 时使用）
# --------------------------------------------
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=rd-files-prod

# --------------------------------------------
# 文件下载 HMAC 签名密钥（≥32 字符）
# --------------------------------------------
FILE_DOWNLOAD_SECRET=

# --------------------------------------------
# 跨域允许的 origin（逗号分隔多个）
# --------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --------------------------------------------
# 企业微信（Phase 1 留空也能跑，仅 OAuth 登录受影响）
# --------------------------------------------
WEWORK_CORP_ID=
WEWORK_AGENT_ID=
WEWORK_SECRET=
WEWORK_MESSAGE_ENABLED=false

# --------------------------------------------
# 企业微信 — 前端 OAuth 登录（VITE_ 前缀，前端 Vite 编译时注入）
# dev 环境可以全部留空 → 企微登录按钮禁用
# 生产环境必须 3 个全填，否则前端企微按钮一直 disabled
# --------------------------------------------
# 企微 corpId（在企业微信管理后台「我的企业」查看）
VITE_WEWORK_CORP_ID=
# 企微应用 agentId（在「应用管理」查看）
VITE_WEWORK_AGENT_ID=
# OAuth 回调地址（必须与企微后台配置的"授权回调域"一致）
# dev: http://localhost:8080/api/auth/wework/callback
# prod: https://api.rd.example.com/api/auth/wework/callback
VITE_WEWORK_OAUTH_REDIRECT_URI=
