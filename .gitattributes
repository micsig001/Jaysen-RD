# 强制 LF 换行（避免 Windows CRLF 导致 Git diff 噪音）
* text=auto eol=lf

# Shell 脚本必须 LF
*.sh text eol=lf
*.ps1 text eol=lf

# Windows 批处理 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制不处理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.jar binary
*.war binary
*.class binary
